// ============================================================================
// BARBERSHOP SAAS - PRISMA SCHEMA (MySQL 8+)
// ----------------------------------------------------------------------------
// Convenções:
// - Todos os valores monetários usam Decimal(12,2) — nunca Float.
// - Todas as entidades de negócio têm createdAt/updatedAt.
// - Nomes de tabela em snake_case via @@map, para SQL legível.
// - Preparado para futura multi-tenant: ver README "Estratégia Multi-Tenant".
// ============================================================================

generator client {
  provider      = "prisma-client-js"
  // "native" cobre o Windows do ambiente de dev; os demais cobrem os
  // servidores Linux (Debian/Ubuntu) mais comuns em hospedagem compartilhada,
  // como a Hostinger — evita o engine da Prisma quebrar em produção por
  // binário incompatível com o SO do servidor.
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
  // Engine "binary" (processo separado) em vez de "library" (addon nativo
  // embutido no processo Node): o engine "library" travava com "PANIC: timer
  // has gone away" no sandbox CageFS da Hostinger — restrição de baixo nível
  // do ambiente compartilhado, não um bug da aplicação.
  engineType    = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// AUTENTICAÇÃO / RBAC
// ----------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String     @map("password_hash")
  phone        String?
  status       UserStatus @default(ACTIVE)
  image        String?

  roles                UserRole[]
  client               Client?
  professional         Professional?
  auditLogs            AuditLog[]
  cashRegistersOpened  CashRegister[]        @relation("CashRegisterOpenedBy")
  cashRegisterClosings CashRegisterClosing[] @relation("CashRegisterClosedBy")
  cashbookEntries      CashbookEntry[]       @relation("CashbookCreatedBy")
  paymentsReceived     Payment[]             @relation("PaymentReceivedBy")
  appointmentsCreated  Appointment[]         @relation("AppointmentCreatedBy")
  messageLogs          MessageLog[]          @relation("MessageSentBy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Role {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique // ADMIN, PROFESSIONAL, ATTENDANT, CASHIER, CLIENT
  description String? @db.Text

  permissions RolePermission[]
  users       UserRole[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique // clients.view, finance.create, etc.
  description String? @db.Text

  roles RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(cuid())
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ----------------------------------------------------------------------------
// CLIENTES
// ----------------------------------------------------------------------------

model Client {
  id                      String       @id @default(cuid())
  userId                  String?      @unique @map("user_id")
  name                    String
  phone                   String?
  whatsapp                String?
  email                   String?
  birthDate               DateTime?    @map("birth_date")
  notes                   String?      @db.Text
  preferredProfessionalId String?      @map("preferred_professional_id")
  status                  ClientStatus @default(ACTIVE)
  totalSpent              Decimal      @default(0) @map("total_spent") @db.Decimal(12, 2)
  lastAppointmentAt       DateTime?    @map("last_appointment_at")
  profileImageId          String?      @map("profile_image_id")

  user                  User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  preferredProfessional Professional? @relation("PreferredProfessional", fields: [preferredProfessionalId], references: [id], onDelete: SetNull)
  profileImage          Media?        @relation("ClientProfileImage", fields: [profileImageId], references: [id], onDelete: SetNull)
  appointments          Appointment[]
  messageLogs           MessageLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([preferredProfessionalId])
  @@map("clients")
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  VIP
}

// ----------------------------------------------------------------------------
// BARBEIROS
// ----------------------------------------------------------------------------

model Professional {
  id                   String             @id @default(cuid())
  userId               String?            @unique @map("user_id")
  fullName             String             @map("full_name")
  professionalName     String             @map("professional_name")
  bio                  String?            @db.Text
  specialties          String?            @db.Text // CSV ou JSON de especialidades
  phone                String?
  whatsapp             String?
  email                String?
  hiredAt              DateTime?          @map("hired_at")
  status               ProfessionalStatus @default(ACTIVE)
  commissionPercentage Decimal            @default(0) @map("commission_percentage") @db.Decimal(5, 2)
  profileImageId       String?            @map("profile_image_id")
  workingHours         Json?              @map("working_hours") // { "mon": ["09:00-19:00"], ... }

  user               User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  profileImage       Media?                @relation("ProfessionalProfileImage", fields: [profileImageId], references: [id], onDelete: SetNull)
  services           ProfessionalService[]
  appointments       Appointment[]
  preferredByClients Client[]              @relation("PreferredProfessional")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("professionals")
}

enum ProfessionalStatus {
  ACTIVE
  INACTIVE
  VACATION
}

// ----------------------------------------------------------------------------
// SERVIÇOS
// ----------------------------------------------------------------------------

model Service {
  id                       String        @id @default(cuid())
  name                     String
  slug                     String        @unique
  shortDescription         String?       @map("short_description")
  description              String?       @db.Text
  price                    Decimal       @db.Decimal(12, 2)
  durationMinutes          Int           @map("duration_minutes")
  category                 String?
  status                   ServiceStatus @default(ACTIVE)
  advertisingImageId       String?       @map("advertising_image_id")
  defaultMessageTemplateId String?       @map("default_message_template_id")

  advertisingImage       Media?                @relation("ServiceAdvertisingImage", fields: [advertisingImageId], references: [id], onDelete: SetNull)
  defaultMessageTemplate MessageTemplate?      @relation(fields: [defaultMessageTemplateId], references: [id], onDelete: SetNull)
  professionals          ProfessionalService[]
  appointmentServices    AppointmentService[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([category])
  @@map("services")
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

model ProfessionalService {
  id                    String        @id @default(cuid())
  professionalId        String        @map("professional_id")
  serviceId             String        @map("service_id")
  customPrice           Decimal?      @map("custom_price") @db.Decimal(12, 2)
  customDurationMinutes Int?          @map("custom_duration_minutes")
  status                ServiceStatus @default(ACTIVE)

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([professionalId, serviceId])
  @@map("professional_services")
}

// ----------------------------------------------------------------------------
// AGENDAMENTOS
// ----------------------------------------------------------------------------

model Appointment {
  id              String            @id @default(cuid())
  clientId        String            @map("client_id")
  professionalId  String            @map("professional_id")
  appointmentDate DateTime          @map("appointment_date") @db.Date
  startTime       DateTime          @map("start_time")
  endTime         DateTime          @map("end_time")
  status          AppointmentStatus @default(PENDING)
  notes           String?           @db.Text
  createdById     String?           @map("created_by_id")

  client       Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  professional Professional         @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  createdBy    User?                @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  services     AppointmentService[]
  payments     Payment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([professionalId])
  @@index([clientId])
  @@index([appointmentDate])
  @@index([status])
  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// Preço e duração são "congelados" no momento do agendamento —
// não dependemos do valor atual do Service para histórico.
model AppointmentService {
  id              String  @id @default(cuid())
  appointmentId   String  @map("appointment_id")
  serviceId       String  @map("service_id")
  price           Decimal @db.Decimal(12, 2)
  durationMinutes Int     @map("duration_minutes")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([appointmentId])
  @@map("appointment_services")
}

// ----------------------------------------------------------------------------
// FINANCEIRO
// ----------------------------------------------------------------------------

model Payment {
  id            String        @id @default(cuid())
  appointmentId String        @map("appointment_id")
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @map("payment_method")
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?     @map("paid_at")
  receivedById  String?       @map("received_by_id")

  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  receivedBy    User?          @relation("PaymentReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)
  cashbookEntry CashbookEntry?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([appointmentId])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  CANCELLED
}

model CashbookEntry {
  id              String            @id @default(cuid())
  type            CashbookEntryType
  description     String
  amount          Decimal           @db.Decimal(12, 2)
  category        String?
  paymentMethod   PaymentMethod?    @map("payment_method")
  appointmentId   String?           @map("appointment_id")
  paymentId       String?           @unique @map("payment_id")
  createdById     String?           @map("created_by_id")
  transactionDate DateTime          @map("transaction_date")
  notes           String?           @db.Text

  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdBy User?    @relation("CashbookCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([transactionDate])
  @@index([type])
  @@map("cashbook_entries")
}

enum CashbookEntryType {
  CREDIT
  DEBIT
}

model CashRegister {
  id             String             @id @default(cuid())
  openedById     String             @map("opened_by_id")
  openedAt       DateTime           @map("opened_at")
  openingBalance Decimal            @map("opening_balance") @db.Decimal(12, 2)
  status         CashRegisterStatus @default(OPEN)

  openedBy User                 @relation("CashRegisterOpenedBy", fields: [openedById], references: [id])
  closing  CashRegisterClosing?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cash_registers")
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

model CashRegisterClosing {
  id              String   @id @default(cuid())
  cashRegisterId  String   @unique @map("cash_register_id")
  closedById      String   @map("closed_by_id")
  closedAt        DateTime @map("closed_at")
  expectedBalance Decimal  @map("expected_balance") @db.Decimal(12, 2)
  actualBalance   Decimal  @map("actual_balance") @db.Decimal(12, 2)
  difference      Decimal  @db.Decimal(12, 2)
  notes           String?  @db.Text

  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  closedBy     User         @relation("CashRegisterClosedBy", fields: [closedById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@map("cash_register_closings")
}

// ----------------------------------------------------------------------------
// COMUNICAÇÃO
// ----------------------------------------------------------------------------

model MessageTemplate {
  id        String         @id @default(cuid())
  name      String
  channel   MessageChannel
  content   String         @db.Text
  variables Json? // ex: ["clientName", "appointmentDate"]
  status    ServiceStatus  @default(ACTIVE)

  logs               MessageLog[]
  defaultForServices Service[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("message_templates")
}

model MessageLog {
  id          String         @id @default(cuid())
  clientId    String         @map("client_id")
  templateId  String?        @map("template_id")
  channel     MessageChannel
  content     String         @db.Text
  status      MessageStatus  @default(SENT)
  sentById    String?        @map("sent_by_id")
  providerRef String?        @map("provider_ref") // id retornado pelo provider externo

  client   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  template MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sentBy   User?            @relation("MessageSentBy", fields: [sentById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([clientId])
  @@map("message_logs")
}

enum MessageChannel {
  WHATSAPP
  SMS
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

// ----------------------------------------------------------------------------
// MÍDIA / ARQUIVOS
// ----------------------------------------------------------------------------

model Media {
  id              String    @id @default(cuid())
  fileName        String    @map("file_name")
  originalName    String    @map("original_name")
  mimeType        String    @map("mime_type")
  fileSize        Int       @map("file_size")
  storageProvider String    @map("storage_provider") // local | s3 | r2 | supabase
  storagePath     String    @map("storage_path")
  mediaType       MediaType @map("media_type")
  width           Int?
  height          Int?

  clientsUsing       Client[]       @relation("ClientProfileImage")
  professionalsUsing Professional[] @relation("ProfessionalProfileImage")
  servicesUsing      Service[]      @relation("ServiceAdvertisingImage")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("media")
}

enum MediaType {
  LOGO
  CLIENT_PROFILE
  PROFESSIONAL_PROFILE
  SERVICE_ADVERTISING
}

// ----------------------------------------------------------------------------
// CONFIGURAÇÕES / AUDITORIA
// ----------------------------------------------------------------------------

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
  type  String @default("string") // string | number | boolean | json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model AuditLog {
  id        String  @id @default(cuid())
  userId    String? @map("user_id")
  action    String
  entity    String
  entityId  String? @map("entity_id")
  oldValues Json?   @map("old_values")
  newValues Json?   @map("new_values")
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent") @db.Text

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
