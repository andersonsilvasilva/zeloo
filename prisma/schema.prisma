// ============================================================================
// BARBERSHOP SAAS - PRISMA SCHEMA (MySQL 8+)
// ----------------------------------------------------------------------------
// Convenções:
// - Todos os valores monetários usam Decimal(12,2) — nunca Float.
// - Todas as entidades de negócio têm createdAt/updatedAt.
// - Nomes de tabela em snake_case via @@map, para SQL legível.
// - Preparado para futura multi-tenant: ver README "Estratégia Multi-Tenant".
// ============================================================================

generator client {
  provider      = "prisma-client-js"
  // "native" cobre o Windows do ambiente de dev; os demais cobrem os
  // servidores Linux (Debian/Ubuntu) mais comuns em hospedagem compartilhada,
  // como a Hostinger — evita o engine da Prisma quebrar em produção por
  // binário incompatível com o SO do servidor.
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
  // Engine "binary" (processo separado) em vez de "library" (addon nativo
  // embutido no processo Node): o engine "library" travava com "PANIC: timer
  // has gone away" no sandbox CageFS da Hostinger — restrição de baixo nível
  // do ambiente compartilhado, não um bug da aplicação.
  engineType    = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// AUTENTICAÇÃO / RBAC
// ----------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String     @map("password_hash")
  phone        String?
  status       UserStatus @default(ACTIVE)
  image        String?

  roles                UserRole[]
  tenantMemberships    TenantUser[]
  client               Client?
  professional         Professional?
  auditLogs            AuditLog[]
  cashRegistersOpened  CashRegister[]        @relation("CashRegisterOpenedBy")
  cashRegisterClosings CashRegisterClosing[] @relation("CashRegisterClosedBy")
  cashbookEntries      CashbookEntry[]       @relation("CashbookCreatedBy")
  paymentsReceived     Payment[]             @relation("PaymentReceivedBy")
  appointmentsCreated  Appointment[]         @relation("AppointmentCreatedBy")
  messageLogs          MessageLog[]          @relation("MessageSentBy")
  pixChargesCreated    PixCharge[]           @relation("PixChargeCreatedBy")
  accountEntriesCreated          AccountEntry[]          @relation("AccountEntryCreatedBy")
  recurringAccountEntriesCreated RecurringAccountEntry[] @relation("RecurringAccountEntryCreatedBy")
  commissionClosingsClosed       CommissionClosing[]     @relation("CommissionClosingClosedBy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Role {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique // ADMIN, PROFESSIONAL, ATTENDANT, CASHIER, CLIENT
  description String? @db.Text

  permissions RolePermission[]
  users       UserRole[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique // clients.view, finance.create, etc.
  description String? @db.Text

  roles RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// tenantId nullable nesta fase (Fase 3, Etapa A — expandir). Fica obrigatório
// e o @@unique passa a incluir tenantId na Etapa C, depois do backfill —
// ver docs/tenancy/02-data-migration.md. Até lá, "um papel por usuário
// globalmente" continua valendo (não por tenant) — é assim que já funciona
// hoje, então nenhum comportamento muda com essa coluna nullable.
model UserRole {
  id       String  @id @default(cuid())
  userId   String  @map("user_id")
  roleId   String  @map("role_id")
  tenantId String? @map("tenant_id")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  // Corrigido na Fase 14 (achado real na verificação do critério "usuário com
  // múltiplos tenants opera em um tenant por vez", spec §67): a constraint
  // original (@@unique([userId, roleId])), de antes da Fase 3 acrescentar
  // tenantId, nunca foi revisada — impedia o MESMO usuário de ter o MESMO
  // papel (ex.: ADMIN) em dois tenants diferentes. Ver
  // docs/tenancy/13-acceptance-criteria.md.
  @@unique([tenantId, userId, roleId])
  @@index([tenantId])
  @@map("user_roles")
}

// ----------------------------------------------------------------------------
// MULTI-TENANCY (Fase 1 — ver docs/tenancy/01-architecture.md)
// ----------------------------------------------------------------------------
// Só tabelas novas nesta fase. Nenhuma tabela acima (User, etc.) foi alterada
// — tenant_id nas tabelas existentes é trabalho da Fase 3 (migração
// expandir->migrar->restringir), ainda não iniciada.

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  status       TenantStatus @default(TRIAL)
  planId       String?      @map("plan_id")
  customDomain String?      @map("custom_domain")
  timezone     String       @default("America/Sao_Paulo")
  locale       String       @default("pt-BR")
  settings     Json?
  trialEndsAt  DateTime?    @map("trial_ends_at")

  members       TenantUser[]
  subscriptions Subscription[]
  limits        TenantLimit[]
  usageRecords  UsageRecord[]

  // Relações inversas das tabelas existentes que ganharam tenant_id
  // nullable na Fase 3, Etapa A (expandir) — ver docs/tenancy/02-data-migration.md.
  userRoles               UserRole[]
  clients                 Client[]
  professionals           Professional[]
  services                Service[]
  appointments            Appointment[]
  payments                Payment[]
  pixCharges              PixCharge[]
  cashbookEntries         CashbookEntry[]
  cashRegisters           CashRegister[]
  cashRegisterClosings    CashRegisterClosing[]
  recurringAccountEntries RecurringAccountEntry[]
  accountEntries          AccountEntry[]
  commissionClosings      CommissionClosing[]
  messageTemplates        MessageTemplate[]
  messageLogs             MessageLog[]
  media                   Media[]
  settingEntries          Setting[] // nome diferente de `settings` (o Json? de branding acima, já existente na Fase 1)
  auditLogs               AuditLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

// Membership: liga um User (identidade global) a um Tenant. Não tem role_id
// (diferente do exemplo conceitual do spec) — a atribuição de papel continua
// via UserRole, que ganha tenant_id na Fase 3 (ver docs/tenancy/01-architecture.md §2).
model TenantUser {
  id       String           @id @default(cuid())
  tenantId String           @map("tenant_id")
  userId   String           @map("user_id")
  status   TenantUserStatus @default(ACTIVE)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, userId])
  @@map("tenant_users")
}

enum TenantUserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

model Plan {
  id     String  @id @default(cuid())
  name   String
  slug   String  @unique
  active Boolean @default(true)

  features      PlanFeature[]
  subscriptions Subscription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

// Uma linha por recurso do plano (ex.: key="appointments_per_month", value="3000",
// key="pix", value="true") — mesmo padrão key-value já usado por `Setting`.
model PlanFeature {
  id     String @id @default(cuid())
  planId String @map("plan_id")
  key    String
  value  String

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
  @@map("plan_features")
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String             @map("tenant_id")
  planId             String             @map("plan_id")
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime?          @map("current_period_start")
  currentPeriodEnd   DateTime?          @map("current_period_end")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

// Override pontual de um limite de plano pra um tenant específico.
model TenantLimit {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  key      String
  value    String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, key])
  @@map("tenant_limits")
}

// Consumo real medido por tenant/período/métrica — base pro UsageLimitService.
model UsageRecord {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  key      String
  period   String // "yyyy-MM"
  value    Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, key, period])
  @@map("usage_records")
}

// ----------------------------------------------------------------------------
// CLIENTES
// ----------------------------------------------------------------------------

model Client {
  id                      String       @id @default(cuid())
  tenantId                String?      @map("tenant_id")
  userId                  String?      @unique @map("user_id")
  name                    String
  phone                   String?
  whatsapp                String?
  email                   String?
  birthDate               DateTime?    @map("birth_date")
  notes                   String?      @db.Text
  preferredProfessionalId String?      @map("preferred_professional_id")
  status                  ClientStatus @default(ACTIVE)
  totalSpent              Decimal      @default(0) @map("total_spent") @db.Decimal(12, 2)
  lastAppointmentAt       DateTime?    @map("last_appointment_at")
  profileImageId          String?      @map("profile_image_id")

  tenant                Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user                  User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  preferredProfessional Professional? @relation("PreferredProfessional", fields: [preferredProfessionalId], references: [id], onDelete: SetNull)
  profileImage          Media?        @relation("ClientProfileImage", fields: [profileImageId], references: [id], onDelete: SetNull)
  appointments          Appointment[]
  messageLogs           MessageLog[]
  accountEntries          AccountEntry[]
  recurringAccountEntries RecurringAccountEntry[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([preferredProfessionalId])
  @@index([tenantId])
  @@map("clients")
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  VIP
}

// ----------------------------------------------------------------------------
// BARBEIROS
// ----------------------------------------------------------------------------

model Professional {
  id                   String             @id @default(cuid())
  tenantId             String?            @map("tenant_id")
  userId               String?            @unique @map("user_id")
  fullName             String             @map("full_name")
  professionalName     String             @map("professional_name")
  bio                  String?            @db.Text
  specialties          String?            @db.Text // CSV ou JSON de especialidades
  phone                String?
  whatsapp             String?
  email                String?
  hiredAt              DateTime?          @map("hired_at")
  status               ProfessionalStatus @default(ACTIVE)
  commissionPercentage Decimal            @default(0) @map("commission_percentage") @db.Decimal(5, 2)
  profileImageId       String?            @map("profile_image_id")
  workingHours         Json?              @map("working_hours") // { "mon": ["09:00-19:00"], ... }

  tenant             Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user               User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  profileImage       Media?                @relation("ProfessionalProfileImage", fields: [profileImageId], references: [id], onDelete: SetNull)
  services           ProfessionalService[]
  appointments       Appointment[]
  preferredByClients Client[]              @relation("PreferredProfessional")
  commissionClosings CommissionClosing[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([tenantId])
  @@map("professionals")
}

enum ProfessionalStatus {
  ACTIVE
  INACTIVE
  VACATION
}

// ----------------------------------------------------------------------------
// SERVIÇOS
// ----------------------------------------------------------------------------

// slug continua @unique global nesta fase (nullable tenantId ainda não
// permite compor a unique com segurança pra registros sem tenant) — vira
// @@unique([tenantId, slug]) na Etapa C, depois do backfill.
model Service {
  id                       String        @id @default(cuid())
  tenantId                 String?       @map("tenant_id")
  name                     String
  slug                     String        @unique
  shortDescription         String?       @map("short_description")
  description              String?       @db.Text
  price                    Decimal       @db.Decimal(12, 2)
  durationMinutes          Int           @map("duration_minutes")
  category                 String?
  status                   ServiceStatus @default(ACTIVE)
  advertisingImageId       String?       @map("advertising_image_id")
  defaultMessageTemplateId String?       @map("default_message_template_id")

  tenant                 Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  advertisingImage       Media?                @relation("ServiceAdvertisingImage", fields: [advertisingImageId], references: [id], onDelete: SetNull)
  defaultMessageTemplate MessageTemplate?      @relation(fields: [defaultMessageTemplateId], references: [id], onDelete: SetNull)
  professionals          ProfessionalService[]
  appointmentServices    AppointmentService[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([category])
  @@index([tenantId])
  @@map("services")
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

model ProfessionalService {
  id                    String        @id @default(cuid())
  professionalId        String        @map("professional_id")
  serviceId             String        @map("service_id")
  customPrice           Decimal?      @map("custom_price") @db.Decimal(12, 2)
  customDurationMinutes Int?          @map("custom_duration_minutes")
  status                ServiceStatus @default(ACTIVE)

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([professionalId, serviceId])
  @@map("professional_services")
}

// ----------------------------------------------------------------------------
// AGENDAMENTOS
// ----------------------------------------------------------------------------

model Appointment {
  id              String            @id @default(cuid())
  tenantId        String?           @map("tenant_id")
  clientId        String            @map("client_id")
  professionalId  String            @map("professional_id")
  appointmentDate DateTime          @map("appointment_date") @db.Date
  startTime       DateTime          @map("start_time")
  endTime         DateTime          @map("end_time")
  status          AppointmentStatus @default(PENDING)
  notes           String?           @db.Text
  createdById     String?           @map("created_by_id")

  tenant       Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  client       Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  professional Professional         @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  createdBy    User?                @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  services     AppointmentService[]
  payments     Payment[]
  pixCharges   PixCharge[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([professionalId])
  @@index([clientId])
  @@index([appointmentDate])
  @@index([status])
  @@index([tenantId])
  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// Preço e duração são "congelados" no momento do agendamento —
// não dependemos do valor atual do Service para histórico.
model AppointmentService {
  id              String  @id @default(cuid())
  appointmentId   String  @map("appointment_id")
  serviceId       String  @map("service_id")
  price           Decimal @db.Decimal(12, 2)
  durationMinutes Int     @map("duration_minutes")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([appointmentId])
  @@map("appointment_services")
}

// ----------------------------------------------------------------------------
// FINANCEIRO
// ----------------------------------------------------------------------------

model Payment {
  id            String        @id @default(cuid())
  tenantId      String?       @map("tenant_id")
  appointmentId String        @map("appointment_id")
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @map("payment_method")
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?     @map("paid_at")
  receivedById  String?       @map("received_by_id")

  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  receivedBy    User?          @relation("PaymentReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)
  cashbookEntry CashbookEntry?
  pixCharge     PixCharge?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([appointmentId])
  @@index([tenantId])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  CANCELLED
}

// Cobrança Pix gerada via Mercado Pago. Fica PENDING até o webhook confirmar
// (ver FinanceService.confirmPixCharge) — só nesse momento um Payment/
// CashbookEntry de verdade é criado. Uma por agendamento por vez: antes de
// criar uma nova, a service checa se já não existe uma PENDING pra mesma
// appointmentId.
model PixCharge {
  id                   String          @id @default(cuid())
  tenantId             String?         @map("tenant_id")
  appointmentId        String          @map("appointment_id")
  mercadoPagoPaymentId String          @unique @map("mercado_pago_payment_id")
  qrCode               String          @map("qr_code") @db.Text
  qrCodeBase64         String          @map("qr_code_base64") @db.Text
  amount               Decimal         @db.Decimal(12, 2)
  status               PixChargeStatus @default(PENDING)
  expiresAt            DateTime?       @map("expires_at")
  paymentId            String?         @unique @map("payment_id")
  createdById          String?         @map("created_by_id")

  tenant      Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  payment     Payment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdBy   User?       @relation("PixChargeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([appointmentId])
  @@index([tenantId])
  @@map("pix_charges")
}

enum PixChargeStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

model CashbookEntry {
  id              String            @id @default(cuid())
  tenantId        String?           @map("tenant_id")
  type            CashbookEntryType
  description     String
  amount          Decimal           @db.Decimal(12, 2)
  category        String?
  paymentMethod   PaymentMethod?    @map("payment_method")
  appointmentId   String?           @map("appointment_id")
  paymentId       String?           @unique @map("payment_id")
  createdById     String?           @map("created_by_id")
  transactionDate DateTime          @map("transaction_date")
  notes           String?           @db.Text

  tenant            Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  payment           Payment?           @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdBy         User?              @relation("CashbookCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  accountEntry      AccountEntry?
  commissionClosing CommissionClosing?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([transactionDate])
  @@index([type])
  @@index([tenantId])
  @@map("cashbook_entries")
}

enum CashbookEntryType {
  CREDIT
  DEBIT
}

model CashRegister {
  id             String             @id @default(cuid())
  tenantId       String?            @map("tenant_id")
  openedById     String?            @map("opened_by_id")
  openedAt       DateTime           @map("opened_at")
  openingBalance Decimal            @map("opening_balance") @db.Decimal(12, 2)
  status         CashRegisterStatus @default(OPEN)

  tenant   Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  openedBy User?                @relation("CashRegisterOpenedBy", fields: [openedById], references: [id], onDelete: SetNull)
  closing  CashRegisterClosing?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("cash_registers")
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

model CashRegisterClosing {
  id              String   @id @default(cuid())
  tenantId        String?  @map("tenant_id")
  cashRegisterId  String   @unique @map("cash_register_id")
  closedById      String?  @map("closed_by_id")
  closedAt        DateTime @map("closed_at")
  expectedBalance Decimal  @map("expected_balance") @db.Decimal(12, 2)
  actualBalance   Decimal  @map("actual_balance") @db.Decimal(12, 2)
  difference      Decimal  @db.Decimal(12, 2)
  notes           String?  @db.Text

  tenant       Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  closedBy     User?        @relation("CashRegisterClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("cash_register_closings")
}

enum AccountDirection {
  PAYABLE
  RECEIVABLE
}

enum AccountEntryStatus {
  PENDING
  SETTLED
  CANCELLED
}

// Template de conta recorrente (ex.: "Aluguel", todo dia 5). AccountService
// gera os AccountEntry de cada mês sob demanda (lazy, na leitura da lista) —
// não existe job/cron; @@unique em AccountEntry garante que nunca duplica.
model RecurringAccountEntry {
  id               String           @id @default(cuid())
  tenantId         String?          @map("tenant_id")
  direction        AccountDirection
  description      String
  amount           Decimal          @db.Decimal(12, 2)
  category         String?
  counterpartyName String?          @map("counterparty_name") // fornecedor (PAYABLE) ou nome livre (RECEIVABLE)
  clientId         String?          @map("client_id") // só RECEIVABLE
  dayOfMonth       Int              @map("day_of_month") // 1-28, evita edge case de meses curtos
  active           Boolean          @default(true)
  createdById      String?          @map("created_by_id")

  tenant    Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  client    Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy User?          @relation("RecurringAccountEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  entries   AccountEntry[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([direction, active])
  @@index([tenantId])
  @@map("recurring_account_entries")
}

// Contas a Pagar (PAYABLE) e a Receber (RECEIVABLE) unificadas num só model,
// mesmo padrão de CashbookEntry.type (CREDIT/DEBIT) — só o "contraparte" muda
// (fornecedor em texto livre vs. cliente opcional). "Vencida" é calculado em
// runtime (status ainda PENDING + dueDate no passado), não armazenado.
model AccountEntry {
  id               String              @id @default(cuid())
  tenantId         String?             @map("tenant_id")
  direction        AccountDirection
  description      String
  amount           Decimal             @db.Decimal(12, 2)
  category         String?
  counterpartyName String?             @map("counterparty_name")
  clientId         String?             @map("client_id")
  dueDate          DateTime            @map("due_date") @db.Date
  status           AccountEntryStatus  @default(PENDING)
  settledAt        DateTime?           @map("settled_at")
  paymentMethod    PaymentMethod?      @map("payment_method")
  cashbookEntryId  String?             @unique @map("cashbook_entry_id")
  recurringEntryId String?             @map("recurring_entry_id")
  createdById      String?             @map("created_by_id")
  notes            String?             @db.Text

  tenant         Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  client         Client?                 @relation(fields: [clientId], references: [id], onDelete: SetNull)
  cashbookEntry  CashbookEntry?          @relation(fields: [cashbookEntryId], references: [id], onDelete: SetNull)
  recurringEntry RecurringAccountEntry?  @relation(fields: [recurringEntryId], references: [id], onDelete: SetNull)
  createdBy      User?                   @relation("AccountEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([recurringEntryId, dueDate])
  @@index([direction, status])
  @@index([dueDate])
  @@index([tenantId])
  @@map("account_entries")
}

// Fechamento de comissão de um profissional num período — mesmo padrão de
// CashRegister/CashRegisterClosing: registro imutável, criado numa transação
// que também gera o CashbookEntry (DEBIT) de pagamento da comissão. Sem
// edição/estorno depois de fechado (ver README do módulo commissions).
model CommissionClosing {
  id               String   @id @default(cuid())
  tenantId         String?  @map("tenant_id")
  professionalId   String   @map("professional_id")
  periodStart      DateTime @map("period_start") @db.Date
  periodEnd        DateTime @map("period_end") @db.Date
  calculatedAmount Decimal  @map("calculated_amount") @db.Decimal(12, 2)
  finalAmount      Decimal  @map("final_amount") @db.Decimal(12, 2)
  adjustmentNotes  String?  @map("adjustment_notes") @db.Text
  cashbookEntryId  String?  @unique @map("cashbook_entry_id")
  closedById       String?  @map("closed_by_id")
  closedAt         DateTime @default(now()) @map("closed_at")

  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  professional  Professional   @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  cashbookEntry CashbookEntry? @relation(fields: [cashbookEntryId], references: [id], onDelete: SetNull)
  closedBy      User?          @relation("CommissionClosingClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  @@unique([professionalId, periodStart, periodEnd])
  @@index([professionalId])
  @@index([tenantId])
  @@map("commission_closings")
}

// ----------------------------------------------------------------------------
// COMUNICAÇÃO
// ----------------------------------------------------------------------------

model MessageTemplate {
  id        String         @id @default(cuid())
  tenantId  String?        @map("tenant_id")
  name      String
  channel   MessageChannel
  content   String         @db.Text
  variables Json? // ex: ["clientName", "appointmentDate"]
  status    ServiceStatus  @default(ACTIVE)

  tenant             Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  logs               MessageLog[]
  defaultForServices Service[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("message_templates")
}

model MessageLog {
  id          String         @id @default(cuid())
  tenantId    String?        @map("tenant_id")
  clientId    String         @map("client_id")
  templateId  String?        @map("template_id")
  channel     MessageChannel
  content     String         @db.Text
  status      MessageStatus  @default(SENT)
  sentById    String?        @map("sent_by_id")
  providerRef String?        @map("provider_ref") // id retornado pelo provider externo

  tenant   Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  client   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  template MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sentBy   User?            @relation("MessageSentBy", fields: [sentById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([clientId])
  @@index([tenantId])
  @@map("message_logs")
}

enum MessageChannel {
  WHATSAPP
  SMS
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

// ----------------------------------------------------------------------------
// MÍDIA / ARQUIVOS
// ----------------------------------------------------------------------------

model Media {
  id              String    @id @default(cuid())
  tenantId        String?   @map("tenant_id")
  fileName        String    @map("file_name")
  originalName    String    @map("original_name")
  mimeType        String    @map("mime_type")
  fileSize        Int       @map("file_size")
  storageProvider String    @map("storage_provider") // local | s3 | r2 | supabase
  storagePath     String    @map("storage_path")
  mediaType       MediaType @map("media_type")
  width           Int?
  height          Int?

  tenant             Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  clientsUsing       Client[]       @relation("ClientProfileImage")
  professionalsUsing Professional[] @relation("ProfessionalProfileImage")
  servicesUsing      Service[]      @relation("ServiceAdvertisingImage")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("media")
}

enum MediaType {
  LOGO
  FAVICON
  OG_IMAGE
  CLIENT_PROFILE
  PROFESSIONAL_PROFILE
  SERVICE_ADVERTISING
}

// ----------------------------------------------------------------------------
// CONFIGURAÇÕES / AUDITORIA
// ----------------------------------------------------------------------------

// key continua @unique global nesta fase — vira @@unique([tenantId, key]) na
// Etapa C. É a tabela mais transversal do sistema (branding, WhatsApp,
// Mercado Pago, endereço) — ver docs/tenancy/00-audit.md §11.
model Setting {
  id       String  @id @default(cuid())
  tenantId String? @map("tenant_id")
  key      String  @unique
  value    String  @db.Text
  type     String  @default("string") // string | number | boolean | json

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("settings")
}

// tenantId nullable de propósito mesmo depois da Etapa C — ações de
// plataforma (ex.: criação de tenant) nunca terão um tenant associado.
model AuditLog {
  id        String  @id @default(cuid())
  tenantId  String? @map("tenant_id")
  userId    String? @map("user_id")
  action    String
  entity    String
  entityId  String? @map("entity_id")
  oldValues Json?   @map("old_values")
  newValues Json?   @map("new_values")
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent") @db.Text

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@index([tenantId])
  @@map("audit_logs")
}
