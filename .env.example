# Banco de dados MySQL 8+
DATABASE_URL="mysql://root:root@127.0.0.1:3306/barbershop_saas"

# Auth.js
AUTH_SECRET="gere-com: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
# Necessário em produção (múltiplos hosts/subdomínios) e pra testar login em
# hostnames diferentes de localhost — ver docs/tenancy/03-auth-sessions.md.
AUTH_TRUST_HOST="true"

# Storage
STORAGE_PROVIDER="local" # local | s3 | r2 | supabase

# Integrações de mensagens (opcional, configurar depois)
WHATSAPP_BUSINESS_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# Nome/idioma do template aprovado na Meta (WhatsApp Manager > Modelos de mensagem).
# Sem um template de barbearia aprovado ainda, usa o "hello_world" de exemplo.
WHATSAPP_TEMPLATE_NAME="hello_world"
WHATSAPP_TEMPLATE_LANGUAGE="en_US"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""
ZENVIA_API_TOKEN=""

# Multi-tenant (Fase 2 — ver docs/tenancy/01b-tenant-resolver.md)
# Feature flag de ativação (Fase 13, spec §64). "false"/ausente = modo
# single-tenant explícito (ignora hostname, tudo opera como ROOT_TENANT_SLUG)
# — use assim em produção até o DNS/SSL wildcard (Fase 12) estarem prontos e
# validados. "true" só depois de validar em produção que os subdomínios
# resolvem e têm certificado válido. Em dev local, deixe "true" pra testar
# de verdade. Ver docs/tenancy/11-deployment-runbook.md.
MULTITENANCY_ENABLED="false"
APP_BASE_DOMAIN="zeloo.net"
TENANCY_MODE="subdomain"
# Slug do tenant servido no domínio raiz (zeloo.net/www.zeloo.net), decisão de
# negócio da Fase 0 — ver docs/tenancy/00-audit.md §12. Var extra não prevista
# literalmente no spec original, necessária por causa dessa decisão.
ROOT_TENANT_SLUG="zeloo"
# Usado só durante migração controlada/compatibilidade temporária — nunca
# fallback silencioso em produção depois da ativação final (spec §14).
DEFAULT_TENANT_SLUG=""
CENTRAL_DOMAINS="zeloo.net,www.zeloo.net,app.zeloo.net,admin.zeloo.net,api.zeloo.net"
# true só atrás de proxy confiável (Nginx da VPS) — nunca em dev direto.
TRUST_PROXY="false"
TENANT_CACHE_PREFIX="tenant"
TENANT_STORAGE_PREFIX="tenants"
